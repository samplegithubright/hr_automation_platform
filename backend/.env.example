# OpenAI API Key (Required for AI features, otherwise mock data is returned)
OPENAI_API_KEY=

# GitHub Personal Access Token (Optional, to bypass unauthenticated rate limits)
GITHUB_TOKEN=

# Database Connection URL
# Fallback is SQLite local db: sqlite+aiosqlite:///./hr_platform.db
# PostgreSQL: postgresql+asyncpg://postgres:postgres@localhost:5432/hr_platform
DATABASE_URL=sqlite+aiosqlite:///./hr_platform.db

# JWT Configuration
JWT_SECRET=super_secret_key_hr_automation_platform_2026_change_me_in_prod
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# File Storage Configuration
# options: "local" or "s3"
STORAGE_TYPE=local
UPLOAD_DIR=uploads

# AWS S3 Settings (Only needed if STORAGE_TYPE=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=us-east-1
